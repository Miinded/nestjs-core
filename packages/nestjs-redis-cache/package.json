{
  "name": "@miinded/nestjs-redis-cache",
  "version": "1.0.1",
  "description": "Production-ready NestJS module for Redis caching with ioredis integration.",
  "license": "MIT",
  "author": "Miinded",
  "repository": {
    "type": "git",
    "url": "https://github.com/Miinded/nestjs-core.git",
    "directory": "packages/nestjs-redis-cache"
  },
  "bugs": {
    "url": "https://github.com/Miinded/nestjs-core/issues"
  },
  "homepage": "https://github.com/Miinded/nestjs-core/tree/main/packages/nestjs-redis-cache",
  "keywords": [
    "nestjs",
    "nest",
    "redis",
    "cache",
    "ioredis",
    "caching",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "tsc --project tsconfig.cjs.json && tsc --project tsconfig.esm.json",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "pnpm test:unit",
    "test:unit": "node ../../config/run-jest.mjs unit",
    "test:unit:debug": "node ../../config/run-jest.mjs unit:debug",
    "test:watch": "node ../../config/run-jest.mjs watch",
    "test:coverage": "node ../../config/run-jest.mjs coverage"
  },
  "dependencies": {
    "@nestjs-modules/ioredis": "^2.0.2",
    "ioredis": "^5.10.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.3.0 || ^11.0.0",
    "@nestjs/core": "^10.3.0 || ^11.0.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@swc/core": "catalog:",
    "@swc/jest": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "jest": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "rxjs": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:"
  }
}
